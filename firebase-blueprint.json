{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "phoneNumber": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Pet": {
      "title": "Pet",
      "description": "Registered pet information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["DOG", "CAT", "OTHER"] },
        "breed": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "weight": { "type": "number" },
        "gender": { "type": "string", "enum": ["MALE", "FEMALE"] },
        "isNeutered": { "type": "boolean" },
        "memo": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "type"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Spending records for pets",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "petId": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "petId", "amount", "category", "date"]
    },
    "PaymentMethod": {
      "title": "Payment Method",
      "description": "Registered credit cards or accounts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["CARD", "ACCOUNT"] },
        "provider": { "type": "string" },
        "lastFour": { "type": "string" },
        "isDefault": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "provider"]
    },
    "Budget": {
      "title": "Monthly Budget",
      "description": "User defined budget for spending categories",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "month": { "type": "string", "description": "YYYY-MM format" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "category", "amount", "month"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or transactional notifications for the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["INFO", "CASHBACK", "WARNING", "EVENT"] },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "type", "isRead", "createdAt"]
    },
    "Reminder": {
      "title": "Medication Reminder",
      "description": "Reminders for medication or recurring care",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "petId": { "type": "string" },
        "itemName": { "type": "string" },
        "frequency": { "type": "number" },
        "duration": { "type": "number" },
        "startDate": { "type": "string" },
        "createdAt": { "type": "string" },
        "isRead": { "type": "boolean" }
      }
    },
    "RecurringExpense": {
      "title": "Recurring Expense",
      "description": "Registered recurring care or subscription",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "petId": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "nextDate": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User"
    },
    "/users/{userId}/pets/{petId}": {
      "schema": "Pet"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction"
    },
    "/users/{userId}/paymentMethods/{methodId}": {
      "schema": "PaymentMethod"
    },
    "/users/{userId}/budgets/{budgetId}": {
      "schema": "Budget"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification"
    },
    "/users/{userId}/reminders/{reminderId}": {
      "schema": "Reminder"
    },
    "/users/{userId}/recurringExpenses/{recId}": {
      "schema": "RecurringExpense"
    }
  }
}
